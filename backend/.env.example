# Mock-AI mode (default true) — runs the full demo flow without Docling/PaddleOCR/Claude.
# Set to false to enable the real pipeline (requires ANTHROPIC_API_KEY and Docling/PaddleOCR installed).
USE_MOCK_AI=true

# Required only when USE_MOCK_AI=false
ANTHROPIC_API_KEY=sk-ant-xxx

DATABASE_URL=sqlite:///./tender_eval.db
